# Copy this file to `.env` at the solution root for local CLI development.
# `.env` is ignored by git. Do not commit real API keys.

# Gemini Developer API key. The CLI loads this before constructing Gemini clients.
GEMINI_API_KEY=

# Optional fallback name also supported by Google tooling.
# GOOGLE_API_KEY=

# Optional Vertex mode. Leave unset or false for Gemini Developer API.
# GOOGLE_GENAI_USE_VERTEXAI=false
# GOOGLE_CLOUD_PROJECT=
# GOOGLE_CLOUD_LOCATION=
